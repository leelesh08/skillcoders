VITE_FIREBASE_API_KEY=REPLACE_ME
VITE_FIREBASE_AUTH_DOMAIN=REPLACE_ME
VITE_FIREBASE_PROJECT_ID=REPLACE_ME
VITE_FIREBASE_STORAGE_BUCKET=REPLACE_ME
VITE_FIREBASE_MESSAGING_SENDER_ID=REPLACE_ME
VITE_FIREBASE_APP_ID=REPLACE_ME
VITE_FIREBASE_MEASUREMENT_ID=REPLACE_ME

# Backend URL used by the frontend API helper (no trailing slash)
VITE_API_URL=https://skillcoderslatest.vercel.app/

# Optional: Publishable key for client-side payment integrations (Stripe, etc.)
# The backend should use the secret key to create checkout sessions.
VITE_STRIPE_PK=REPLACE_WITH_STRIPE_PUBLISHABLE_KEY
